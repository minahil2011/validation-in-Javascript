<!DOCTYPE html>
<html>
    <head>
        <title>
            Event registration form
        </title>
        <style>
            body{
                font-family:cursive;
                background-color:#0a0a0a;
                color: #222222;
                text-align:center;
            }
            .form-card{
                width:520px;
                background-color: rgb(10, 10, 10);
                border: 3px solid #ffffff;
                border-radius: 18px;
                margin: 40px auto;
                padding: 25px;
                box-shadow: 0 0 100px #93c5fd;
            }
            h1{
                color:rgb(253, 254, 255);
            }
            label{
                display:block;
                text-align:left;
                margin-top:12px;
            }
            input,
            select {
                width:95%;
                padding:10px;
                margin-top:6px;
                border:2px solid #feffff;
                border-radius:6px;
                font-size:15px;
                background-color: #0a0a0a;
                color: #ffffff;
            }
            button{
                background-color:#ffffff;
                color:rgb(5, 5, 5);
                border:none;
                border-radius:25px;
                padding:12px 24px;
                font-size:15px;
                cursor:pointer;
                margin-top:18px;
            }
            button:hover{
                background-color:#ffffff;
            }
            #feedback{
                margin-top:20px;
                padding:15px;
                border-radius:12px;
                line-height:1.6;
                color: #ffffff;
            }
            .success{
                background-color:#dcfce7;
                color:#166534;
                border:2px solid #22c55e;
            }
            .error {
                background-color: #f82828;
                color: #0c0c0c;
                border: 2px solid #ffffff;
            }
            p,
            label{
                color:#ffffff;
            }
        </style>
    </head>
    <body>
        <div class="form-card">
            <h1>
                EVENT REGISTRATION FORM
            </h1>
            <p>
                Fill the form to register for the Tech Event 
                and generate the event pass.
            </p>
            <form id="event-form">
                <label for="studentName">
                    Student Name
                </label>
                <input type="text" id="studentName" required minLength="3"
                placeHolder="Enter your name">
                <label for="email">
                    Email Address
                </label>
                <input type="email" id="email" placeHolder="Enter your email">
                <label for="age">
                    Age
                </label>
                <input type="number" id="age" required min="8" max="18"
                placeHolder="Enter your age">
                <label for="eventName">
                    Choose Event
                </label>
                <select id="eventName" required>
                    <option value="Tech Carnival">
                        Tech Carnival
                    </option>
                    <option value="Code Arena">
                        Code Arena
                    </option>
                    <option value="EchoTech">
                        EchoTech
                    </option>
                    <option value="TechGirls">
                        TechGirls
                    </option>
                </select>
                <button type="button" onclick="registerEvent()">
                    Register Now!
                </button>
            </form>
            <div id="feedback">
                Waiting For Registration....
            </div>
        </div>
        <script>
            function registerEvent(){
                let form     = document.getElementById("event-form");
                let feedback = document.getElementById("feedback");

                try{
                    if(!form.checkValidity()){
                        throw form.reprtValidity();
                    }

                    //accessing form data
                    let studentName = document.getElementById("studentName").value;
                    let email       = document.getElementById("email").value;
                    let age         = document.getElementById("age").value;
                    let eventName   = document.getElementById("eventName").value;

                    //writing validation conditions
                    if (studentName.length < 3){
                        throw "Name must have at least 3 characters.";
                    }
                    if (age < 8 || age > 18){
                        throw "Age must be between 8 and 18.";
                    }

                    //DOM feedback before timer
                    feedback.className="";
                    feedback.innerHTML = "Checking your registeration details...";

                    //timer and random numbers
                    setTimeout(function(){
                        let passNumber = 
                        Math.floor(Math.random() * 9000) + 1000;
                        feedback.className = "Success!";
                        feedback.innerHTML= "Registeration Successful!!!<br>"+
                        "Student name: " + studentName + "<br>" + 
                        "Email: " + email + "<br>" + "Age: " + age + "<br>"
                        + "Event: " + eventName + "<br>" + 
                        "Your Event Pass Number: EVT- " + passNumber;                   
                    }, 2000);
                }
                catch(error){
                    //dom feedback for error
                    feedback.className= "error";
                    if(error !== undefined){
                        feedback.innerHTML = "Resteration Failed: " + error;
                    }
                    else{
                        feedback.innerHTML = "Please fill all required feilds correctly.";
                    }
                }
            }
        </script>
    </body>
</html>
